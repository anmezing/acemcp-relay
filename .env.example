# Server Configuration
SERVER_ADDR=127.0.0.1:3009

# LCE MCP Configuration
# Streamable HTTP endpoint of the LCE MCP server
LCE_MCP_URL=http://127.0.0.1:3000/mcp

# Debug Capture (optional)
# Comma-separated path list. Prints request/response body previews to log.
# Temporary troubleshooting only; may contain code or user input — clear when done.
# Example: /agents/codebase-retrieval,/batch-upload
DEBUG_CAPTURE_PATHS=
DEBUG_CAPTURE_MAX_BYTES=4096

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_NAME=postgres

# Redis Configuration
REDIS_PORT=6379
API_KEY_CACHE_TTL=1h

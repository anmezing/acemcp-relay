# Server Configuration
SERVER_ADDR=127.0.0.1:3009

# Augment API Configuration
AUGMENT_API_URL=https://your-api-url.com
AUGMENT_API_TOKEN=your-api-token-here

# Upstream Proxy (optional)
# 配置后所有发往上游 Augment API 的请求都会走该代理。
# 留空则回退到标准的 HTTP_PROXY / HTTPS_PROXY / NO_PROXY 环境变量。
# 支持 http/https/socks5，例如：http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
UPSTREAM_PROXY=

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_NAME=postgres

# Redis Configuration
REDIS_PORT=6379
API_KEY_CACHE_TTL=1h

# Session Configuration
SESSION_TTL=5m
